# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL / Supabase
# Use the pooled connection string at runtime and the direct connection for migrations.
DATABASE_URL=postgresql://postgres:password@localhost:5432/affluo?schema=public
DIRECT_URL=postgresql://postgres:password@localhost:5432/affluo?schema=public
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Local demo seed only — never expose this key to the application or the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DEMO_USER_PASSWORD=replace-with-a-local-demo-password

# Internal CSV imports
CSV_IMPORT_MAX_BYTES=5242880
CSV_IMPORT_MAX_ROWS=1000

# Patrimoine Radar — disabled unless explicitly enabled.
DETECTION_ENABLED=false
DETECTION_SCHEDULER_ENABLED=false
DETECTION_LLM_ENABLED=false
DETECTION_SOURCE_BODACC_ENABLED=false
DETECTION_SOURCE_BODACC_DEMO_ENABLED=false
DETECTION_SOURCE_BODACC_INTERVAL_MINUTES=1440
DETECTION_MAX_DOCUMENTS_PER_RUN=50
DETECTION_MAX_DOCUMENT_ATTEMPTS=3
DETECTION_MINIMUM_SCORE=75
DETECTION_MAXIMUM_SIGNAL_AGE_DAYS=120
DETECTION_STALE_RUN_MINUTES=30
DETECTION_BODACC_API_URL=https://bodacc-datadila.opendatasoft.com/api/explore/v2.1/catalog/datasets/annonces-commerciales/records
CRON_SECRET=replace-with-a-long-random-value

# Planned integrations — unused unless their feature is explicitly enabled.
OPENAI_API_KEY=your-openai-api-key
RESEND_API_KEY=your-resend-api-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
