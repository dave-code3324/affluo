# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL / Supabase
# Use the pooled connection string at runtime and the direct connection for migrations.
DATABASE_URL=postgresql://postgres:password@localhost:5432/affluo?schema=public
DIRECT_URL=postgresql://postgres:password@localhost:5432/affluo?schema=public
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Planned integrations — unused by the current authentication and onboarding scope.
OPENAI_API_KEY=your-openai-api-key
RESEND_API_KEY=your-resend-api-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
