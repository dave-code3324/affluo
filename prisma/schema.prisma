generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  MEMBER
  ADMIN

  @@map("user_role")
}

enum WeeklyBatchStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("weekly_batch_status")
}

enum VerificationStatus {
  UNVERIFIED
  LIKELY
  VERIFIED
  INVALID

  @@map("verification_status")
}

enum ContactabilityStatus {
  NOT_CONTACTABLE
  PARTIALLY_VERIFIED
  CONTACTABLE

  @@map("contactability_status")
}

enum OpportunityStatus {
  DRAFT
  PUBLISHED
  DISMISSED

  @@map("opportunity_status")
}

enum ConfidenceLevel {
  LOW
  MEDIUM
  HIGH

  @@map("confidence_level")
}

enum SignalVerificationStatus {
  UNVERIFIED
  VERIFIED
  REJECTED

  @@map("signal_verification_status")
}

enum ContactDetailType {
  PROFESSIONAL_EMAIL
  PROFESSIONAL_PHONE
  LINKEDIN
  COMPANY_WEBSITE

  @@map("contact_detail_type")
}

enum FeedbackDecision {
  TO_CONTACT
  TO_MONITOR
  NOT_RELEVANT

  @@map("feedback_decision")
}

enum FeedbackReason {
  WRONG_PROFILE
  WEAK_SIGNAL
  WRONG_LOCATION
  ALREADY_KNOWN
  INSUFFICIENT_CONTACT_DETAILS
  OTHER

  @@map("feedback_reason")
}

enum ImportStatus {
  UPLOADED
  VALIDATING
  READY
  IMPORTING
  COMPLETED
  FAILED

  @@map("import_status")
}

enum ImportRowStatus {
  PENDING
  VALID
  INVALID
  DUPLICATE
  IMPORTED
  SKIPPED

  @@map("import_row_status")
}

enum DuplicateResolution {
  SKIP
  UPDATE_EXISTING
  CREATE_DISTINCT

  @@map("duplicate_resolution")
}

enum DuplicateMatchLevel {
  STRONG
  SECONDARY

  @@map("duplicate_match_level")
}

enum OpportunityReviewStatus {
  TO_REVIEW
  IN_REVIEW
  NEEDS_CHANGES
  APPROVED
  REJECTED

  @@map("opportunity_review_status")
}

enum OpportunityRejectionReason {
  OUT_OF_TARGET
  INSUFFICIENT_SIGNAL
  STALE_SIGNAL
  UNRELIABLE_SOURCE
  INSUFFICIENT_CONTACT_DETAILS
  DUPLICATE
  COMPLIANCE_RISK
  OTHER

  @@map("opportunity_rejection_reason")
}

enum OpportunityOrigin {
  CSV_IMPORT
  AUTOMATED_DETECTION
  MANUAL

  @@map("opportunity_origin")
}

enum SourceDocumentProcessingStatus {
  COLLECTED
  PROCESSING
  PROCESSED
  IGNORED
  FAILED

  @@map("source_document_processing_status")
}

enum DetectionRunStatus {
  PENDING
  RUNNING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED

  @@map("detection_run_status")
}

enum DetectionRunItemStatus {
  COLLECTED
  PROCESSING
  PROCESSED
  IGNORED
  FAILED

  @@map("detection_run_item_status")
}

enum DetectionSignalType {
  COMPANY_SALE
  BUSINESS_TRANSFER
  FUNDRAISING
  MANAGEMENT_CHANGE
  COMPANY_CREATION
  COMPANY_CLOSURE
  DIVIDEND_EVENT
  REAL_ESTATE_TRANSACTION
  PROFESSIONAL_SUCCESSION
  LIQUIDITY_EVENT
  OTHER

  @@map("detection_signal_type")
}

enum ExtractionMethod {
  DETERMINISTIC
  LLM

  @@map("extraction_method")
}

enum ExtractionInvocationStatus {
  PENDING
  COMPLETED
  FAILED

  @@map("extraction_invocation_status")
}

model User {
  id                    String                @id @db.Uuid
  email                 String                @unique
  emailConfirmedAt      DateTime?             @map("email_confirmed_at") @db.Timestamptz(6)
  createdAt             DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  role                  UserRole              @default(MEMBER)
  memberships           FirmMember[]
  reviewedOpportunities Opportunity[]         @relation("OpportunityReviewer")
  feedbacks             OpportunityFeedback[]
  createdImports        DataImport[]
  auditLogs             AuditLog[]
  verifiedContacts      ContactDetail[]       @relation("ContactVerifier")
  detectionRuns         DetectionRun[]

  @@map("users")
}

model Company {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  normalizedName   String     @map("normalized_name")
  website          String?
  normalizedDomain String?    @unique @map("normalized_domain")
  legalName        String     @map("legal_name")
  tradeName        String?    @map("trade_name")
  siren            String?    @unique
  siret            String?    @unique
  city             String?
  department       String?
  industry         String?
  legalForm        String?    @map("legal_form")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  prospects        Prospect[]

  @@index([normalizedName])
  @@map("companies")
}

model Firm {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  city                  String
  department            String
  onboardingCompletedAt DateTime?             @map("onboarding_completed_at") @db.Timestamptz(6)
  createdAt             DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  members               FirmMember[]
  preferences           FirmPreference?
  weeklyBatches         WeeklyBatch[]
  opportunities         Opportunity[]
  opportunityFeedbacks  OpportunityFeedback[]

  @@map("firms")
}

model FirmMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firmId    String   @map("firm_id") @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  role      String   @default("owner")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  firm      Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([firmId, userId])
  @@index([firmId])
  @@map("firm_members")
}

model FirmPreference {
  firmId                 String   @id @map("firm_id") @db.Uuid
  nationwide             Boolean  @default(false)
  prospectingDepartments String[] @default([]) @map("prospecting_departments")
  targetProfiles         String[] @default([]) @map("target_profiles")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  firm                   Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@map("firm_preferences")
}

model WeeklyBatch {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firmId        String            @map("firm_id") @db.Uuid
  weekStart     DateTime          @map("week_start") @db.Date
  weekEnd       DateTime          @map("week_end") @db.Date
  status        WeeklyBatchStatus @default(DRAFT)
  publishedAt   DateTime?         @map("published_at") @db.Timestamptz(6)
  summary       String?
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  firm          Firm              @relation(fields: [firmId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]

  @@unique([firmId, weekStart])
  @@index([firmId, status, publishedAt])
  @@map("weekly_batches")
}

model Prospect {
  id                         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName                  String             @map("first_name")
  lastName                   String             @map("last_name")
  jobTitle                   String             @map("job_title")
  companyName                String             @map("company_name")
  city                       String
  department                 String
  linkedinUrl                String?            @map("linkedin_url")
  professionalEmail          String?            @map("professional_email")
  emailVerificationStatus    VerificationStatus @default(UNVERIFIED) @map("email_verification_status")
  professionalProfileSummary String?            @map("professional_profile_summary")
  companyId                  String?            @map("company_id") @db.Uuid
  identificationSource       String?            @map("identification_source")
  identificationConfidence   Int?               @map("identification_confidence")
  createdAt                  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  opportunities              Opportunity[]
  signals                    Signal[]
  contactDetails             ContactDetail[]
  company                    Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdImportRows          ImportRow[]        @relation("CreatedProspect")
  duplicateImportRows        ImportRow[]        @relation("DuplicateProspect")

  @@index([department])
  @@map("prospects")
}

model Opportunity {
  id                   String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firmId               String?                     @map("firm_id") @db.Uuid
  weeklyBatchId        String?                     @map("weekly_batch_id") @db.Uuid
  prospectId           String                      @map("prospect_id") @db.Uuid
  title                String
  signalType           String                      @map("signal_type")
  signalSummary        String                      @map("signal_summary")
  whyNow               String                      @map("why_now")
  relevanceScore       Int                         @map("relevance_score")
  contactabilityStatus ContactabilityStatus        @default(NOT_CONTACTABLE) @map("contactability_status")
  status               OpportunityStatus           @default(DRAFT)
  confidenceLevel      ConfidenceLevel             @default(MEDIUM) @map("confidence_level")
  qualificationSummary String?                     @map("qualification_summary")
  potentialNeeds       String[]                    @default([]) @map("potential_needs")
  reviewedAt           DateTime?                   @map("reviewed_at") @db.Timestamptz(6)
  reviewedByUserId     String?                     @map("reviewed_by") @db.Uuid
  reviewStatus         OpportunityReviewStatus     @default(TO_REVIEW) @map("review_status")
  rejectionReason      OpportunityRejectionReason? @map("rejection_reason")
  internalNotes        String?                     @map("internal_notes")
  origin               OpportunityOrigin           @default(MANUAL)
  automaticScore       Int?                        @map("automatic_score")
  automaticConfidence  ConfidenceLevel?            @map("automatic_confidence")
  detectionRunId       String?                     @map("detection_run_id") @db.Uuid
  createdAt            DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  firm                 Firm?                       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  weeklyBatch          WeeklyBatch?                @relation(fields: [weeklyBatchId], references: [id], onDelete: Cascade)
  prospect             Prospect                    @relation(fields: [prospectId], references: [id], onDelete: Restrict)
  reviewer             User?                       @relation("OpportunityReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  signals              OpportunitySignal[]
  feedbacks            OpportunityFeedback[]
  createdImportRow     ImportRow?                  @relation("CreatedOpportunity")
  detectionRun         DetectionRun?               @relation(fields: [detectionRunId], references: [id], onDelete: SetNull)

  @@unique([weeklyBatchId, prospectId])
  @@index([firmId, status])
  @@index([weeklyBatchId, status, relevanceScore])
  @@index([detectionRunId])
  @@map("opportunities")
}

model Signal {
  id                 String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prospectId         String                   @map("prospect_id") @db.Uuid
  type               String
  title              String
  description        String
  eventDate          DateTime?                @map("event_date") @db.Date
  detectedAt         DateTime                 @map("detected_at") @db.Timestamptz(6)
  sourceUrl          String?                  @map("source_url")
  sourceName         String?                  @map("source_name")
  sourcePublishedAt  DateTime?                @map("source_published_at") @db.Timestamptz(6)
  verificationStatus SignalVerificationStatus @default(UNVERIFIED) @map("verification_status")
  verifiedAt         DateTime?                @map("verified_at") @db.Timestamptz(6)
  sourceDocumentId   String?                  @unique @map("source_document_id") @db.Uuid
  confidenceLevel    ConfidenceLevel          @default(MEDIUM) @map("confidence_level")
  extractionMethod   ExtractionMethod         @default(DETERMINISTIC) @map("extraction_method")
  extractionVersion  String                   @default("deterministic-v1") @map("extraction_version")
  createdAt          DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  prospect           Prospect                 @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  opportunities      OpportunitySignal[]
  sourceDocument     SourceDocument?          @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([prospectId, verificationStatus])
  @@map("signals")
}

model OpportunitySignal {
  opportunityId String      @map("opportunity_id") @db.Uuid
  signalId      String      @map("signal_id") @db.Uuid
  isPrimary     Boolean     @default(false) @map("is_primary")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  signal        Signal      @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@id([opportunityId, signalId])
  @@index([signalId])
  @@map("opportunity_signals")
}

model ContactDetail {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prospectId         String             @map("prospect_id") @db.Uuid
  type               ContactDetailType
  value              String
  verificationStatus VerificationStatus @default(UNVERIFIED) @map("verification_status")
  verificationMethod String?            @map("verification_method")
  verifiedAt         DateTime?          @map("verified_at") @db.Timestamptz(6)
  verifiedByUserId   String?            @map("verified_by_user_id") @db.Uuid
  isPrimary          Boolean            @default(false) @map("is_primary")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  prospect           Prospect           @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  verifiedBy         User?              @relation("ContactVerifier", fields: [verifiedByUserId], references: [id], onDelete: SetNull)

  @@unique([prospectId, type, value])
  @@index([prospectId, verificationStatus])
  @@map("contact_details")
}

model OpportunityFeedback {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  opportunityId String           @map("opportunity_id") @db.Uuid
  firmId        String           @map("firm_id") @db.Uuid
  userId        String           @map("user_id") @db.Uuid
  decision      FeedbackDecision
  reason        FeedbackReason?
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  opportunity   Opportunity      @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  firm          Firm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, firmId])
  @@index([firmId, decision])
  @@index([userId])
  @@map("opportunity_feedback")
}

model DataImport {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdByUserId String       @map("created_by_user_id") @db.Uuid
  filename        String
  contentHash     String       @map("content_hash")
  status          ImportStatus @default(UPLOADED)
  failureMessage  String?      @map("failure_message")
  totalRows       Int          @default(0) @map("total_rows")
  validRows       Int          @default(0) @map("valid_rows")
  invalidRows     Int          @default(0) @map("invalid_rows")
  duplicateRows   Int          @default(0) @map("duplicate_rows")
  processedRows   Int          @default(0) @map("processed_rows")
  startedAt       DateTime?    @map("started_at") @db.Timestamptz(6)
  completedAt     DateTime?    @map("completed_at") @db.Timestamptz(6)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy       User         @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  rows            ImportRow[]

  @@index([createdAt])
  @@index([status])
  @@map("imports")
}

model ImportRow {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importId              String               @map("import_id") @db.Uuid
  rowNumber             Int                  @map("row_number")
  rawData               Json                 @map("raw_data")
  normalizedData        Json?                @map("normalized_data")
  status                ImportRowStatus      @default(PENDING)
  errorMessages         Json                 @default("[]") @map("error_messages")
  duplicateOfProspectId String?              @map("duplicate_of_prospect_id") @db.Uuid
  duplicateMatchLevel   DuplicateMatchLevel? @map("duplicate_match_level")
  duplicateResolution   DuplicateResolution? @map("duplicate_resolution")
  createdProspectId     String?              @map("created_prospect_id") @db.Uuid
  createdOpportunityId  String?              @unique @map("created_opportunity_id") @db.Uuid
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  dataImport            DataImport           @relation(fields: [importId], references: [id], onDelete: Cascade)
  duplicateOfProspect   Prospect?            @relation("DuplicateProspect", fields: [duplicateOfProspectId], references: [id], onDelete: SetNull)
  createdProspect       Prospect?            @relation("CreatedProspect", fields: [createdProspectId], references: [id], onDelete: SetNull)
  createdOpportunity    Opportunity?         @relation("CreatedOpportunity", fields: [createdOpportunityId], references: [id], onDelete: SetNull)

  @@unique([importId, rowNumber])
  @@index([importId, status])
  @@map("import_rows")
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId  String   @map("actor_user_id") @db.Uuid
  action       String
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  previousData Json?    @map("previous_data")
  newData      Json?    @map("new_data")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  actor        User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

model DetectionRun {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceKey             String                 @map("source_key")
  status                DetectionRunStatus     @default(PENDING)
  startedAt             DateTime?              @map("started_at") @db.Timestamptz(6)
  completedAt           DateTime?              @map("completed_at") @db.Timestamptz(6)
  documentsCollected    Int                    @default(0) @map("documents_collected")
  documentsProcessed    Int                    @default(0) @map("documents_processed")
  signalsDetected       Int                    @default(0) @map("signals_detected")
  prospectsCreated      Int                    @default(0) @map("prospects_created")
  opportunitiesCreated  Int                    @default(0) @map("opportunities_created")
  opportunitiesIgnored  Int                    @default(0) @map("opportunities_ignored")
  errorsCount           Int                    @default(0) @map("errors_count")
  metadata              Json?
  launchedByUserId      String?                @map("launched_by_user_id") @db.Uuid
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  launchedBy            User?                  @relation(fields: [launchedByUserId], references: [id], onDelete: SetNull)
  items                 DetectionRunItem[]
  opportunities         Opportunity[]
  extractionInvocations ExtractionInvocation[]

  @@index([sourceKey, createdAt])
  @@index([status])
  @@map("detection_runs")
}

model SourceDocument {
  id                    String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceKey             String                         @map("source_key")
  externalId            String?                        @map("external_id")
  sourceUrl             String                         @map("source_url")
  title                 String
  rawContent            String                         @map("raw_content")
  contentHash           String                         @map("content_hash")
  publishedAt           DateTime?                      @map("published_at") @db.Timestamptz(6)
  collectedAt           DateTime                       @map("collected_at") @db.Timestamptz(6)
  processingStatus      SourceDocumentProcessingStatus @default(COLLECTED) @map("processing_status")
  processingError       String?                        @map("processing_error")
  metadata              Json?
  createdAt             DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)
  runItems              DetectionRunItem[]
  signals               Signal[]
  extractionInvocations ExtractionInvocation[]

  @@unique([sourceKey, externalId])
  @@unique([sourceKey, sourceUrl])
  @@unique([sourceKey, contentHash])
  @@index([processingStatus, collectedAt])
  @@map("source_documents")
}

model DetectionRunItem {
  id               String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  detectionRunId   String                 @map("detection_run_id") @db.Uuid
  sourceDocumentId String                 @map("source_document_id") @db.Uuid
  status           DetectionRunItemStatus @default(COLLECTED)
  rejectionReasons String[]               @default([]) @map("rejection_reasons")
  matchingReasons  String[]               @default([]) @map("matching_reasons")
  errorMessage     String?                @map("error_message")
  attemptCount     Int                    @default(0) @map("attempt_count")
  nextRetryAt      DateTime?              @map("next_retry_at") @db.Timestamptz(6)
  durationMs       Int?                   @map("duration_ms")
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  detectionRun     DetectionRun           @relation(fields: [detectionRunId], references: [id], onDelete: Cascade)
  sourceDocument   SourceDocument         @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)

  @@unique([detectionRunId, sourceDocumentId])
  @@index([detectionRunId, status])
  @@map("detection_run_items")
}

model ExtractionInvocation {
  id              String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  detectionRunId  String                     @map("detection_run_id") @db.Uuid
  inputDocumentId String                     @map("input_document_id") @db.Uuid
  provider        String
  model           String
  promptVersion   String                     @map("prompt_version")
  output          Json?
  latencyMs       Int?                       @map("latency_ms")
  inputTokens     Int?                       @map("input_tokens")
  outputTokens    Int?                       @map("output_tokens")
  status          ExtractionInvocationStatus @default(PENDING)
  errorMessage    String?                    @map("error_message")
  createdAt       DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  detectionRun    DetectionRun               @relation(fields: [detectionRunId], references: [id], onDelete: Cascade)
  inputDocument   SourceDocument             @relation(fields: [inputDocumentId], references: [id], onDelete: Cascade)

  @@index([detectionRunId])
  @@index([inputDocumentId])
  @@map("extraction_invocations")
}
